{
  "name": "agentic-crew",
  "version": "1.0.3",
  "description": "Scaffold a full AI engineering team into any project — personas, wired and ready in 60 seconds.",
  "main": "src/api.js",
  "types": "index.d.ts",
  "exports": {
    ".": "./src/api.js",
    "./cli": "./src/index.js",
    "./schema/manifest.schema.json": "./schema/manifest.schema.json"
  },
  "bin": {
    "agentic-crew": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "schema/",
    "examples/",
    "docs/",
    "CONTRIBUTING.md",
    "index.d.ts",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "test": "node --test --test-concurrency=1 $(find test -name '*.test.js' | sort | tr '\\n' ' ')",
    "test:smoke": "node bin/cli.js init --dry-run --yes --name smoke --frontend react --backend go --domain ml,data --output-dir test/.tmp/smoke-dry",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "ai-agents",
    "multi-agent",
    "scaffolding",
    "cli",
    "agentic",
    "engineering-team",
    "cursor",
    "claude",
    "codex",
    "windsurf"
  ],
  "author": "Savitha Gollamudi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/g-savitha/agentic-crew.git"
  },
  "bugs": {
    "url": "https://github.com/g-savitha/agentic-crew/issues"
  },
  "homepage": "https://github.com/g-savitha/agentic-crew#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8"
  }
}
